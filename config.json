  "chunk_min_size": 200,
  "chunk_max_size": 2000,
  "max_transcript_tokens": 10000,
  "max_context_tokens": 190000,
  "embedding_batch_size": 32,
  "indexing_workers": 3,
  "transcription_workers": 5,
  "deepgram_model": "nova-3",
  "deepgram_language": "el"
}
